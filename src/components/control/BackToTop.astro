---
import { Icon } from "astro-icon/components";
---

<div id="back-to-top-btn" class="fixed bottom-6 right-6 z-50 transition-all duration-300" onclick="backToTop()">
    <button aria-label="Back to Top" class="h-9 w-9 rounded-xl shadow-2xl flex items-center justify-center bg-[var(--card-bg)] text-[var(--primary)] border border-[var(--line-color)] hover:bg-[var(--btn-card-bg-hover)] active:scale-95 transition-colors">
        <Icon name="material-symbols:keyboard-arrow-up-rounded" class="text-lg"></Icon>
    </button>
</div>

<style>
#back-to-top-btn {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
}
#back-to-top-btn.hide {
    opacity: 0;
    transform: translateY(1rem);
    pointer-events: none;
}
</style>

<script is:inline>
function backToTop() {
    const start = window.scrollY || document.documentElement.scrollTop || 0;
    const duration = 500;
    const startTime = performance.now();

    function easeOutCubic(t) {
        return 1 - Math.pow(1 - t, 3);
    }

    function step(now) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const amount = easeOutCubic(progress);
        window.scrollTo(0, Math.max(0, Math.floor(start * (1 - amount))));
        if (progress < 1) {
            requestAnimationFrame(step);
        }
    }

    requestAnimationFrame(step);
}
</script>
